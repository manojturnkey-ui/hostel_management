SECRET_KEY=change-this-secret-key
DEBUG=True
REQUIRE_POSTGRESQL=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=Asia/Kolkata
SERVE_MEDIA_FILES=True
PANEL_ADMIN_EMAIL=admin@example.com
PANEL_ADMIN_USERNAME=admin@example.com
PANEL_ADMIN_PASSWORD=change-this-password
PANEL_ADMIN_NAME=Hostel Admin
WHATSAPP_SCAN_BASE_URL=http://127.0.0.1:3001
WHATSAPP_SCAN_API_KEY=
WHATSAPP_SCAN_TIMEOUT=15
WHATSAPP_SCAN_DEFAULT_COUNTRY_CODE=91
WHATSAPP_SCAN_SESSION_NAME=autoans-session

# PostgreSQL is required for local testing and deployment.
# Preferred Render / production database style
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/hostel_management

# Optional separate PostgreSQL variables if DATABASE_URL is not used
DB_NAME=hostel_management
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=prefer
